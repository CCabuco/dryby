rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedUser() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function reviewKeysValid(data) {
      return data.keys().hasAll([
        "shopId",
        "orderId",
        "userUid",
        "userName",
        "rating",
        "comment",
        "createdAt",
        "updatedAt",
      ]) &&
      data.keys().hasOnly([
        "shopId",
        "orderId",
        "userUid",
        "userName",
        "rating",
        "comment",
        "createdAt",
        "updatedAt",
      ]);
    }

    function reviewPayloadValid(data, shopId, orderId) {
      return reviewKeysValid(data)
        && data.shopId == shopId
        && data.orderId == orderId
        && data.userUid == request.auth.uid
        && data.userName is string
        && data.userName.size() >= 2
        && data.userName.size() <= 80
        && data.comment is string
        && data.comment.size() <= 500
        && data.comment.size() >= 0
        && exists(/databases/$(database)/documents/laundryShops/$(shopId)/orders/$(orderId))
        && get(/databases/$(database)/documents/laundryShops/$(shopId)/orders/$(orderId)).data.customerUid == request.auth.uid
        && get(/databases/$(database)/documents/laundryShops/$(shopId)/orders/$(orderId)).data.status == "completed"
        && get(/databases/$(database)/documents/laundryShops/$(shopId)/orders/$(orderId)).data.completedAt is timestamp
        && request.time <= get(/databases/$(database)/documents/laundryShops/$(shopId)/orders/$(orderId)).data.completedAt + duration.value(7, "d")
        && (data.rating is int || data.rating is float)
        && data.rating >= 1
        && data.rating <= 5;
    }

    function shopOwnerUid(shopId) {
      return get(/databases/$(database)/documents/laundryShops/$(shopId)).data.ownerUid;
    }

    function isShopOwner(shopId) {
      return signedIn() && shopOwnerUid(shopId) == request.auth.uid;
    }

    function canReviewShop(shopId) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/laundryShops/$(shopId)/reviewEligibleUsers/$(request.auth.uid)
        );
    }

    function isTransactionShopOwner() {
      return signedIn()
        && resource.data.shopId is string
        && exists(/databases/$(database)/documents/laundryShops/$(resource.data.shopId))
        && shopOwnerUid(resource.data.shopId) == request.auth.uid;
    }

    // User profile
    match /users/{uid} {
      allow read, create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;

      // Per-user cached distance snapshots
      match /shopDistances/{shopId} {
        allow read, create, update: if signedIn() && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    // Main shop collection
    match /laundryShops/{shopId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      // Review eligibility grants generated when an order is completed.
      match /reviewEligibleUsers/{uid} {
        allow read: if signedIn() && (uid == request.auth.uid || isShopOwner(shopId));
        allow create, update: if isShopOwner(shopId)
          && request.resource.data.shopId == shopId
          && request.resource.data.userUid == uid;
        allow delete: if isShopOwner(shopId);
      }

      // Real user reviews only (1 review per completed order, within 7 days)
      match /reviews/{reviewId} {
        allow read: if true;

        allow create: if verifiedUser()
          && reviewPayloadValid(request.resource.data, shopId, reviewId)
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if false;

        allow delete: if false;
      }

      // Shop services managed by owner, visible to all users
      match /services/{serviceId} {
        allow read: if true;
        allow create, update, delete: if isShopOwner(shopId);
      }

      // Shop orders: customers create/read own; owners read/update all for their shop
      match /orders/{orderId} {
        allow create: if signedIn()
          && request.resource.data.customerUid == request.auth.uid
          && request.resource.data.shopId == shopId;

        allow read: if signedIn()
          && (resource.data.customerUid == request.auth.uid || isShopOwner(shopId));

        allow update: if signedIn()
          && (isShopOwner(shopId) || resource.data.customerUid == request.auth.uid);

        allow delete: if signedIn() && isShopOwner(shopId);
      }
    }

    // User-facing transaction history
    match /transactions/{transactionId} {
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow read: if signedIn() && resource.data.userUid == request.auth.uid;
      allow update: if signedIn() && (resource.data.userUid == request.auth.uid || isTransactionShopOwner());
      allow delete: if false;
    }

    // Optional top-level collections used by account audit sync
    match /orders/{orderId} {
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userUid == request.auth.uid;
      allow delete: if false;
    }

    match /laundries/{laundryId} {
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userUid == request.auth.uid;
      allow delete: if false;
    }

    // Public announcements for everyone
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
